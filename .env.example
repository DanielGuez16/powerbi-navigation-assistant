# =============================================================================
# REQUIRED — language model + embeddings
# =============================================================================
# Used by both LLMConnector and EMBEDDINGConnector. Get a key from
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional — point to Azure OpenAI or any OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/v1

# Optional — model overrides (sensible defaults are used if unset)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# OPTIONAL — refresh metadata.json from a real Power BI tenant
# Only needed if you run `python powerbi_connector.py` to crawl your tenant.
# Skip this block to use the bundled sample data.
# =============================================================================
# POWERBI_TENANT_ID=
# POWERBI_CLIENT_ID=
# POWERBI_CLIENT_SECRET=


# =============================================================================
# OPTIONAL — load/save glossaries from SharePoint instead of local Excel files
# Set USE_SHAREPOINT=true to enable. Otherwise glossaries live in
# data/glossaries/ as plain Excel files.
# =============================================================================
# USE_SHAREPOINT=false
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=
# SHAREPOINT_SITE_HOSTNAME=yourtenant.sharepoint.com
# SHAREPOINT_SITE_RELATIVE_PATH=/sites/YourSite


# =============================================================================
# OPTIONAL — corporate proxy settings
# =============================================================================
# HTTP_PROXY=
# HTTPS_PROXY=
# BUSINESS_HTTP_PROXY=
# BUSINESS_HTTPS_PROXY=
